{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "resource.gitcoin.co"
        }
      ],
      "destination": "https://dharma.gift/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.upwardspiral.io"
        }
      ],
      "destination": "https://dharma.gift/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "upwardspiral.io"
        }
      ],
      "destination": "https://dharma.gift/:path*",
      "permanent": false
    }
  ]
}
